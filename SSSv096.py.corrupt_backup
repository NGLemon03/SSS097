def plot_stock_price(df: pd.DataFrame, trades_df: pd.DataFrame, ticker: str) -> go.Figure:
    """
    иқңиҠҫЛҠ?вҲ е·Ё?еҜһо№ө?пӢ¬зңәйһҲ?зё‘??
    
    Args:
        df (pd.DataFrame): ?еҜһо№ө?иұў?,?пҶҜо’” close з”Ҳп„‘?.
        trades_df (pd.DataFrame): йҲӯж–—?й–®оҰә?,?пҶҜо’” trade_date, type, price.
        ticker (str): ?вҲ е·Ёйҡһ??.
    
    Returns:
        go.Figure: Plotly ?оЎҝвҖқ?жӢҗиҫЈ.
    """
    # ?пҺү??жҫҶ?йҲӯж–—?йһҲпӢӘ?еҡ—п—јв…ЎйқҪоіҲ?иқҜжӣ№???trade_date + type + price з”Ҳп„‘?
    trades_df = normalize_trades_for_plots(trades_df, price_series=df.get("open", df["close"]))
    
    fig = go.Figure()
    fig.add_trace(go.Scatter(x=df.index, y=df['close'], name='Close Price', line=dict(color='dodgerblue')))
    
    if not trades_df.empty:
        # ?жӣүоҜӯ trades_df ж’Ңи„©??пҗҘзөһйҠқВҖ??trade_date + type + price з”Ҳп„‘?
        buys = trades_df[trades_df['type'] == 'buy']
        adds = trades_df[trades_df['type'] == 'add'] if 'add' in trades_df['type'].values else pd.DataFrame()

        # ?оңӮ ?ВҖ?пүҚиҝӨж’ЈиІүйғҪ?з®„?ж’ҳз‘•пҚ—ж’ҹе–іВҖ?
        all_sells = trades_df[trades_df['type'].str.contains('sell', case=False, na=False)]
        normal_sells = all_sells[~all_sells['type'].str.contains('forced', case=False, na=False)]
        forced_sells = all_sells[all_sells['type'].str.contains('forced', case=False, na=False)]

        # иқңиҠҫЛҠйһҺз‘•п…ҜйқҪвҲҹ?
        if not buys.empty:
            fig.add_trace(go.Scatter(
                x=buys['trade_date'],
                y=buys['price'],
                mode='markers',
                name='Buy',
                marker=dict(symbol='cross', size=10, color='green')
            ))

        # иқңиҠҫЛҠ?оә в…ЈйқҪвҲҹ?
        if not adds.empty:
            fig.add_trace(go.Scatter(
                x=adds['trade_date'],
                y=adds['price'],
                mode='markers',
                name='Add-On Buy',
                marker=dict(symbol='cross', size=10, color='limegreen')
            ))

        # иқңиҠҫЛҠз”Ү?иҷңйһҲ?пҠҫйқҪвҲҹ?еҡ—пҺҲ??д№©зё‘?оёӢ?
        if not normal_sells.empty:
            fig.add_trace(go.Scatter(
                x=normal_sells['trade_date'],
                y=normal_sells['price'],
                mode='markers',
                name='Sell',
                marker=dict(symbol='x', size=10, color='red')
            ))

        # ?оңӮ иқңиҠҫЛҠж’ҳз‘•пҚ—ж’ҹе–іВҖпҗӯ??оөҘи‘«иқҜо“Ҹ?еҡ—?
        if not forced_sells.empty:
            fig.add_trace(go.Scatter(
                x=forced_sells['trade_date'],
                y=forced_sells['price'],
                mode='markers',
                name='End Valid (Forced)',
                marker=dict(symbol='square', size=8, color='gray')
            ))
    
    fig.update_layout(title=f'{ticker} ?вҲӘпҒү?пӢЁжјұ?оҡӨзё‘??,
                      xaxis_title='?дәӨ?', yaxis_title='?еҜһо№ө', template='plotly_white')
    return fig

