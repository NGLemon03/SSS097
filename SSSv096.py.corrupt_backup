def _extract_strategy_names(raw_strategies: Optional[List]) -> List[str]:
    names: List[str] = []
    for item in (raw_strategies or []):
        if isinstance(item, dict):
            name = str(item.get("name", "")).strip()
        else:
            name = str(item).strip()
        if not name:
            continue
        if name.endswith(".csv"):
            name = name[:-4]
        names.append(name)
    return names


def _build_ensemble_result(
    params: Dict,
    ticker: str,
    df_raw: pd.DataFrame,
    strategy_names: Optional[List[str]] = None,
) -> Tuple[pd.DataFrame, Dict]:
    _warn_ensemble_moved_once()

    p = params.get("params", {}) if isinstance(params.get("params", {}), dict) else {}
    c = params.get("trade_cost", {}) if isinstance(params.get("trade_cost", {}), dict) else {}
    strategies = strategy_names if strategy_names is not None else list(params.get("strategies", []) or [])

    ens_params = EnsembleParams(
        floor=float(p.get("floor", 0.2)),
        ema_span=int(p.get("ema_span", 3)),
        delta_cap=float(p.get("delta_cap", 0.3)),
        majority_k=int(p.get("majority_k", 6)),
        min_cooldown_days=int(p.get("min_cooldown_days", 1)),
        min_trade_dw=float(p.get("min_trade_dw", 0.05)),
        delta_cap_buy=(float(p["delta_cap_buy"]) if p.get("delta_cap_buy") is not None else None),
        delta_cap_sell=(float(p["delta_cap_sell"]) if p.get("delta_cap_sell") is not None else None),
        enable_asymmetric=bool(p.get("enable_asymmetric", False)),
    )
    cost_params = CostParams(
        discount_rate=float(c.get("discount_rate", 0.3)),
        buy_fee_bp=float(c.get("buy_fee_bp", 4.27)),
        sell_fee_bp=float(c.get("sell_fee_bp", 4.27)),
        sell_tax_bp=float(c.get("sell_tax_bp", 30.0)),
    )
    cfg = RunConfig(
        ticker=str(params.get("ticker", ticker) or ticker),
        method=str(params.get("method", "proportional")),
        strategies=strategies,
        params=ens_params,
        cost=cost_params,
    )
    if params.get("majority_k_pct") is not None:
        cfg.majority_k_pct = float(params.get("majority_k_pct"))

    open_px, w, trades, stats, method_name, equity, daily_state, trade_ledger = run_ensemble(cfg, price_df=df_raw)

    trade_df = trades.copy() if isinstance(trades, pd.DataFrame) else pd.DataFrame(trades if trades is not None else [])
    if "trade_date" in trade_df.columns:
        trade_df["trade_date"] = pd.to_datetime(trade_df["trade_date"], errors="coerce")
    if "trade_date" in trade_df.columns and not trade_df.empty:
        trade_df = trade_df.sort_values("trade_date")

    ledger_df = trade_ledger.copy() if isinstance(trade_ledger, pd.DataFrame) else trade_df.copy()
    if "trade_date" in ledger_df.columns:
        ledger_df["trade_date"] = pd.to_datetime(ledger_df["trade_date"], errors="coerce")
        ledger_df = ledger_df.sort_values("trade_date")

    if not trade_df.empty and {"trade_date", "type", "price"}.issubset(trade_df.columns):
        signals_df = trade_df[["trade_date", "type", "price"]].rename(columns={"type": "action"}).copy()
    else:
        signals_df = pd.DataFrame(columns=["trade_date", "action", "price"])

    if isinstance(open_px, pd.Series) and not open_px.empty:
        ind_index = open_px.index
    elif isinstance(df_raw, pd.DataFrame) and not df_raw.empty:
        ind_index = df_raw.index
    else:
        ind_index = pd.Index([])

    if isinstance(df_raw, pd.DataFrame) and "close" in df_raw.columns:
        smaa_series = pd.to_numeric(df_raw["close"], errors="coerce")
    elif isinstance(df_raw, pd.DataFrame) and "Close" in df_raw.columns:
        smaa_series = pd.to_numeric(df_raw["Close"], errors="coerce")
    elif isinstance(open_px, pd.Series):
        smaa_series = pd.to_numeric(open_px, errors="coerce")
    else:
        smaa_series = pd.Series(dtype=float)

    df_ind = pd.DataFrame(index=ind_index)
    df_ind["smaa"] = smaa_series.reindex(ind_index) if isinstance(smaa_series, pd.Series) else np.nan
    if isinstance(open_px, pd.Series):
        df_ind["smaa"] = df_ind["smaa"].fillna(open_px.reindex(df_ind.index))

    result = {
        "trades": [],
        "trade_df": trade_df,
        "trades_df": trade_df.copy(),
        "signals_df": signals_df,
        "metrics": stats if isinstance(stats, dict) else {},
        "equity_curve": equity if isinstance(equity, pd.Series) else pd.Series(dtype=float),
        "daily_state": daily_state if isinstance(daily_state, pd.DataFrame) else pd.DataFrame(),
        "weight_curve": w if isinstance(w, pd.Series) else pd.Series(dtype=float),
        "trade_ledger": ledger_df,
        "method_name": method_name,
    }
    return df_ind, result

