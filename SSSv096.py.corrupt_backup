def plot_equity_cash(trades_or_ds: pd.DataFrame, df_raw: pd.DataFrame | None = None) -> go.Figure:
    """
    ?иҠё??дәҷ???['equity','cash'] з”Ҳп„‘???daily_state??
    ?дәҷоҫҰ?и„–??п„“оҰҖйҲӯж–—?йҠөеүҒ?зҳқоҳү? equity/cashеҡ—пҗӯ??пҡ—?й–°иЎЈоңҺйҲӯж–—??пҡ—йҒЈ??
    
    Args:
        trades_or_ds: зҳҘоҗІоЈҷ?ВҖ??DataFrame ?оЎ»жјұ?оҡЁвҖқ DataFrame
        df_raw: ?еҜһо№ө?иұў? DataFrameеҡ—пҺҲоң…?жҪ®?ж’ұз®ё??п“Ғоӯҡиқәо«ә?
    
    Returns:
        go.Figure: Plotly ?оЎҝвҖқ?жӢҗиҫЈ
    """
    if isinstance(trades_or_ds, pd.DataFrame) and {'equity','cash'}.issubset(trades_or_ds.columns):
        # ?иҠё?йӣҝиј»оң… daily_state
        ds = trades_or_ds.copy()
        if not np.issubdtype(ds.index.dtype, np.datetime64):
            ds.index = pd.to_datetime(ds.index)
        ds = ds.sort_index()
        
        # йҡһ?daily_state ?ж№”оҚ”?жҖ ??пҡЎ??о«Ҝ?з”ҲвҲӘо»»з‘ј?йқҪоіӢоӘө
        if 'position_value' in ds.columns:
            try:
                corr = pd.Series(ds['equity']).corr(pd.Series(ds['cash']))
                looks_like_position_value = (corr is not None and corr < -0.95)
                if looks_like_position_value:
                    eq_fixed = ds['position_value'] + ds['cash']
                    ds = ds.copy()
                    ds['equity'] = eq_fixed  # ?иҠё?иқҹжӣү?
            except Exception:
                pass
        
        fig = go.Figure()
        fig.add_trace(go.Scatter(x=ds.index, y=ds['equity'], name='Equity', line=dict(color='dodgerblue')))
        fig.add_trace(go.Scatter(x=ds.index, y=ds['cash'],   name='Cash',   line=dict(color='gray')))
        fig.update_layout(title='з”Ҳп“Ӯ? & ?жҡё?', xaxis_title='?дәӨ?', yaxis_title='?о•Ҝ?', template='plotly_white')
        return fig
    else:
        # ?п“ғжҘқж•әо•ө?йҲӯж–—?йҠө???з’…о©”??оЎј??пҡ—йҒЈеҡ—пҢҲnsemble ?п„‘жјұ?оҡЁвҖқ?о«°иҷңиқ»?sharesеҡ—п—№?йқҪоіҠ??о“Һ?еҡ—?
        try:
            trades_df = normalize_trades_for_plots(trades_or_ds)
            ds = reconstruct_equity_cash_from_trades(trades_df, df_raw)  # йӣҝоәҹоЈ–?пҗҘ??пҡ—йҒЈ?оҗҙж‘©
            
            # йқҪоіҮ?з”Ҳп„‘?
            for col in ['equity', 'cash']:
                if col not in ds.columns:
                    raise KeyError(f"daily_state иқ»з®Ҹ?ж•№пҶІ?з”Ҳп„‘?: {col}")
            
            fig = go.Figure()
            fig.add_trace(go.Scatter(x=ds.index, y=ds['equity'], name='Equity', line=dict(color='dodgerblue')))
            fig.add_trace(go.Scatter(x=ds.index, y=ds['cash'],   name='Cash',   line=dict(color='gray')))
            title = 'з”Ҳп“Ӯ? & ?жҡё?'
            if 'recon_mode' in ds.columns and not ds.empty:
                recon_mode = str(ds['recon_mode'].iloc[-1])
                if recon_mode == 'estimated_fixed_qty':
                    title = 'з”Ҳп“Ӯ? & ?жҡё? (Estimated quantity - not for performance decisions)'
            fig.update_layout(title=title, xaxis_title='?дәӨ?', yaxis_title='?о•Ҝ?', template='plotly_white')
