            return go.Figure()


def plot_weight_series(daily_state: pd.DataFrame, trades_df: pd.DataFrame = None) -> go.Figure:
    """
    иқңиҠҫЛҠ?ојј?з”Ҳп“„?йңҲп“Җ??оўҶ?йҠқиЎҢ?иқ·з®„??оўҖ?
    
    Args:
        daily_state: зҳҘоҗІоЈҷ?ВҖ??DataFrameеҡ—п—ҫ??пҶҜо’”з”Ҳп“„??иіҠ?з”Ҳп„‘?
        trades_df: йҲӯж–—?йһҲпӢӘ? DataFrameеҡ—п—јоң…?жҪӯ?иқ·з®„??оўҖ?еҡ—пҺҶоҸ»?иіӮ?
    
    Returns:
        go.Figure: Plotly ?оЎҝвҖқ?жӢҗиҫЈ
    """
    ds = daily_state.copy()
    if not isinstance(ds.index, pd.DatetimeIndex):
        ds.index = pd.to_datetime(ds.index, errors='coerce')
    ds = ds.sort_index()

    # ?иҠё??пүҢ?еҡ—оӘӨ ??invested_pct ??cash_pctеҡ—пҺҲоң… 1 - cash_pctеҡ—?
    if 'w' in ds.columns:
        w = ds['w']
    elif 'invested_pct' in ds.columns:
        w = ds['invested_pct']
    elif 'cash_pct' in ds.columns:
        w = 1 - ds['cash_pct']
    else:
        return go.Figure()  # ?вҲӘоҸ»?еҶҪ?йӣҝпҡҳ??оөӨоҫҰиқӣз®Ҹ?

    fig = go.Figure()
    
    # йҠқйӨү?з”Ҳп“„??и„©?
    fig.add_trace(go.Scatter(
        x=w.index, 
        y=w, 
        name='?ојј?з”Ҳп“„?',
        line=dict(color='dodgerblue', width=2),
        mode='lines'
    ))
    
    # жҶ’оҝҷ??пҗўжјұ?оҡЁ??о©қ?з’…о©•е…§йңҲп“Җ?жҡә?
    if trades_df is not None and not trades_df.empty:
        # иқЈз®”?йҲӯж–—?йһҲпӢӘ??пҗЈ?й–¬ојҪ?з”Ҳп„‘?
        if 'trade_date' in trades_df.columns and 'type' in trades_df.columns:
            # ?оҺ•и•Ә?пҗӨ??п„‘жјұ?оҡҰоЈҷ??
            valid_trades = trades_df[
                (trades_df['trade_date'].notna()) & 
                (trades_df['trade_date'].isin(w.index))
            ].copy()
            
            if not valid_trades.empty:
                # ж’ пӢЁжјұ?оҡҰоЈҷ?оё„??о®Ҹоҫӯdatetime
                valid_trades['trade_date'] = pd.to_datetime(valid_trades['trade_date'])
                
                # ?з®ё?иқ‘пүӢжјұ?оҡҰпҸј?е•Ј??пҗҘ?з”Ҳп“„???
                trade_points = []
                for _, trade in valid_trades.iterrows():
                    trade_date = trade['trade_date']
                    if trade_date in w.index:
                        weight_value = w.loc[trade_date]
                        trade_type = trade['type']
                        
                        # ?еҜһ?йҲӯж–—?жҶҝоөӨ?зҳҷз®Ҹ?з’…о©–?з’…??
                        if trade_type in ('buy', 'add'):
                            marker_symbol = 'triangle-up'
                            marker_color = 'green'
                            marker_size = 10
                        elif trade_type == 'sell':
                            marker_symbol = 'triangle-down'
                            marker_color = 'red'
                            marker_size = 10
                        else:
                            marker_symbol = 'circle'
                            marker_color = 'orange'
                            marker_size = 8
                        
                        trade_points.append({
                            'date': trade_date,
                            'weight': weight_value,
                            'type': trade_type,
                            'symbol': marker_symbol,
                            'color': marker_color,
                            'size': marker_size
                        })
                
                # зҳӣйӨғ?йңҲп“Җ?жҡәоөҘ?й–®?
                if trade_points:
                    # йһҺз‘•п…Ҝ/?оә в…Јжҡә?
                    buy_points = [p for p in trade_points if p['type'] in ('buy', 'add')]
                    if buy_points:
                        fig.add_trace(go.Scatter(
                            x=[p['date'] for p in buy_points],
