def reconstruct_equity_cash_from_trades(trades_df: pd.DataFrame, df_raw: pd.DataFrame | None = None) -> pd.DataFrame:
    """
    Reconstruct equity and cash curves from trades.

    Priority:
    1) Use explicit quantity columns (shares/qty/quantity) when present.
    2) Fall back to fixed quantity estimation.
    """
    if trades_df is None or trades_df.empty or df_raw is None or df_raw.empty:
        return pd.DataFrame()

    required_cols = ['trade_date', 'type', 'price']
    if not all(col in trades_df.columns for col in required_cols):
        logger.warning(f"Trade dataframe missing required columns: {required_cols}")
        return pd.DataFrame()

    dates = pd.DatetimeIndex(df_raw.index)
    initial_cash = 1_000_000.0
    cash_series = pd.Series(initial_cash, index=dates, dtype=float)
    shares_series = pd.Series(0.0, index=dates, dtype=float)

    trades_df = trades_df.copy()
    trades_df['trade_date'] = pd.to_datetime(trades_df['trade_date'], errors='coerce')
    trades_df['price'] = pd.to_numeric(trades_df['price'], errors='coerce')
    trades_df['type'] = trades_df['type'].astype(str).str.lower().str.strip()

    qty_col = next((c for c in ['shares', 'qty', 'quantity'] if c in trades_df.columns), None)
    recon_mode = 'actual_qty' if qty_col is not None else 'estimated_fixed_qty'

    if qty_col is not None:
        trades_df['trade_qty'] = pd.to_numeric(trades_df[qty_col], errors='coerce').abs()
    else:
        trades_df['trade_qty'] = np.nan

    for _, row in trades_df.iterrows():
        dt = row['trade_date']
        px = row['price']
        t_type = row['type']

        if pd.isna(dt) or pd.isna(px) or dt not in dates:
            continue

        if recon_mode == 'actual_qty':
            qty = row['trade_qty']
            if pd.isna(qty) or qty <= 0:
                continue
            shares = float(qty)
        else:
            shares = 1000.0

        if t_type in ('buy', 'add', 'entry', 'long'):
            shares_series.loc[dt:] += shares
            cash_series.loc[dt:] -= shares * px
        elif t_type in ('sell', 'exit', 'sell_forced', 'forced_sell', 'short'):
            current_shares = float(shares_series.loc[dt])
            if recon_mode == 'actual_qty':
                shares_to_sell = min(current_shares, shares)
                shares_series.loc[dt:] -= shares_to_sell
                cash_series.loc[dt:] += shares_to_sell * px
            else:
                shares_to_sell = current_shares
                shares_series.loc[dt:] = 0.0
                cash_series.loc[dt:] += shares_to_sell * px

    close_col = 'close' if 'close' in df_raw.columns else 'Close'
    if close_col not in df_raw.columns:
        logger.warning('Price dataframe missing close/Close column for reconstruction')
        return pd.DataFrame()

    equity_series = cash_series + shares_series * pd.to_numeric(df_raw[close_col], errors='coerce')

    result = pd.DataFrame({
        'equity': equity_series,
        'cash': cash_series,
        'recon_mode': recon_mode,
    })

    return result
