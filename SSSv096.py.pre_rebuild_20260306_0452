    # ?湔?閮?? SMAA嚗?? joblib.Memory ???敹怠?
    smaa = calc_smaa(df_cleaned['close'], linlen, factor, smaalen)
    
    # 閮?? short ??long ?望???base ??sd
    base_s = smaa.ewm(alpha=1/short_win, adjust=False, min_periods=short_win).mean()
