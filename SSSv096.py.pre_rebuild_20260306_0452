@cfg.MEMORY.cache
def compute_RMA(
    df: pd.DataFrame,
    smaa_source_df: pd.DataFrame,
    linlen: int,
    factor: float,
    smaalen: int,
    rma_len: int,
    dev_len: int,
    smaa_source: str = "Self",
    pine_parity_mode: bool = False,
) -> pd.DataFrame:
    """
    rma_len: ?冽? EMA(base) ???蝒?
    dev_len: ?冽? rolling std(sd) ???蝒?
    smaa_source: 敹怠???敺???怎垢?喳?
    """
    # 皞??鞈??
    source_df   = smaa_source_df if not smaa_source_df.empty else df
    if pine_parity_mode and not smaa_source_df.empty and "close" in source_df.columns:
        source_df = source_df.copy()
        # Pine parity: factor signal uses previous bar value to avoid look-ahead.
        source_df["close"] = source_df["close"].shift(1)
    df_cleaned  = source_df.dropna(subset=['close'])
    df_cleaned['close'] = df_cleaned['close'].round(6)  # 0001FIX:璅????移摨?
    
    # ?湔?閮?? SMAA嚗?? joblib.Memory ???敹怠?
    smaa = calc_smaa(df_cleaned['close'], linlen, factor, smaalen)

    # 閮?? base / sd
    base = smaa.ewm(alpha=1/rma_len, adjust=False, min_periods=rma_len).mean()
    sd   = smaa.rolling(window=dev_len, min_periods=dev_len).std(ddof=0 if pine_parity_mode else 1)

    # 蝯????蝯?DataFrame
    results = pd.DataFrame({
        'smaa': smaa,
        'base': base,
        'sd':   sd
    }, index=df_cleaned.index)
    final = pd.concat([df[['open','high','low','close']], results], axis=1, join='inner')
    final = final.dropna()  # 蝘駁? NaN 銵?雿??????????
    if final.empty:
        logger.warning(f"??蝯?DataFrame ?箇征,?航???SMAA ?豢?銝?雲,蝑??: single, linlen={linlen}, smaalen={smaalen}, data_len={len(df_cleaned)}, valid_smaa={len(smaa.dropna())}")
    return final

