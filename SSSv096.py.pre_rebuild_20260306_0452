    results_df = pd.DataFrame({
        'smaa': smaa,
        'base': base_s,
        'sd': sd_s,
        'base_long': base_l,
        'sd_long': sd_l
    }, index=df_cleaned.index)
    final_df = pd.concat([df[['open', 'high', 'low', 'close']], results_df], axis=1, join='inner')
    final_df = final_df.dropna()  # 蝘駁? NaN 銵?雿??????????
